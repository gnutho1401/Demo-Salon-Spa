PORT=5000
JWT_SECRET=your_jwt_secret_here
DB_TYPE=mssql

DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_SERVER=your_db_host_or_ip
DB_DATABASE=your_db_name
DB_PORT=1433
DB_TRUSTED_CONNECTION=false
DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true
DB_TRUST_CERT=true

# Database URL format for some ORMs or quick connect
DATABASE_URL=mssql://username:password@host:1433/dbname

# Email settings
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# URLs
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=https://your-backend-domain.com

# Google Login
GOOGLE_CLIENT_ID=your_google_client_id

# VNPay / MoMo / PayOS Keys (Replace with your actual keys from providers)
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=https://your-backend-domain.com/api/payments/vnpay-return
VNP_IPN_URL=https://your-backend-domain.com/api/payments/vnpay-ipn

PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

PAYOS_PAYOUT_CLIENT_ID=
PAYOS_PAYOUT_API_KEY=
PAYOS_PAYOUT_CHECKSUM_KEY=

# AI API Keys
OPENROUTER_API_KEY=
GEMINI_API_KEY=
REPLICATE_API_TOKEN=

# AI Service configurations
LOCAL_HAIR_API_URL=https://your-ai-worker-domain.com
AI_HAIR_PROVIDER_ORDER=local
AI_HAIR_LOCAL_ENABLED=true
AI_HAIR_JOB_TIMEOUT_MS=900000

AI_TOTAL_TIMEOUT_MS=12000
AI_VISION_TIMEOUT_MS=5000
AI_CHAT_TIMEOUT_MS=10000
AI_STYLIST_TIMEOUT_MS=5000
AI_VISION_CACHE_TTL_MS=300000
AI_VISION_LOCAL_ENABLED=true
AI_VISION_PROVIDER_ORDER=local,gemini,openrouter
AI_VISION_API_ENHANCE_ENABLED=true
AI_VISION_LOCAL_TIMEOUT_MS=45000
AI_STYLIST_API_ENHANCE_ENABLED=true
AI_JOB_WORKER_ENABLED=true
AI_JOB_POLL_INTERVAL_MS=2000
