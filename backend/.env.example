PORT=5000
JWT_SECRET=your_jwt_secret_key_here
DB_TYPE=mssql

DB_USER=sa
DB_PASSWORD=your_mssql_password_here
DB_SERVER=localhost
DB_DATABASE=BeautySalonSystem
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_CERT=true

# Email verification / forgot password (app password, not account password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password_here
FRONTEND_URL=http://localhost:5173

# Google login
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# VNPay config
BACKEND_URL=http://localhost:5000
VNP_TMN_CODE=your_vnp_tmn_code_here
VNP_HASH_SECRET=your_vnp_hash_secret_here
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5000/api/payments/vnpay-return
VNP_IPN_URL=http://localhost:5000/api/payments/vnpay-ipn

# MoMo sandbox config
MOMO_PARTNER_CODE=your_momo_partner_code_here
MOMO_ACCESS_KEY=your_momo_access_key_here
MOMO_SECRET_KEY=your_momo_secret_key_here
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_QUERY_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/query
MOMO_REFUND_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/refund
MOMO_RETURN_URL=http://localhost:5173/customer/payment-result
MOMO_IPN_URL=http://localhost:5000/api/payments/momo-ipn

# PayOS sandbox / production config - https://payos.vn
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here

# PayOS Payout config
PAYOS_PAYOUT_CLIENT_ID=your_payos_payout_client_id_here
PAYOS_PAYOUT_API_KEY=your_payos_payout_api_key_here
PAYOS_PAYOUT_CHECKSUM_KEY=your_payos_payout_checksum_key_here

# AI Service Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase PostgreSQL Connection String (Pooler - IPv4)
DATABASE_URL=postgresql://your_db_username:your_db_password@your_supabase_host:6543/postgres

# Replicate API Key for Face Analysis / AI Vision
REPLICATE_API_TOKEN=your_replicate_api_token_here
