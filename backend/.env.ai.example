# AI Stylist image-provider settings. Copy these entries into backend/.env.
# Zero-fee, privacy-first mode. No paid provider is called when order contains only local.
AI_VISION_LOCAL_ENABLED=true
AI_VISION_PROVIDER_ORDER=gemini,openrouter,local
# API analyzes first; BiSeNet local remains the privacy-safe validation/fallback path.
AI_VISION_STRATEGY=api-first
AI_VISION_API_ENHANCE_ENABLED=true
AI_VISION_LOCAL_TIMEOUT_MS=45000
AI_VISION_TIMEOUT_MS=5000
AI_VISION_API_MAX_ATTEMPTS=2
AI_VISION_OPENROUTER_MODEL_ATTEMPTS=1
AI_STYLIST_API_ENHANCE_ENABLED=true
AI_STYLIST_TIMEOUT_MS=3000
AI_STYLIST_API_MAX_ATTEMPTS=1

AI_HAIR_PROVIDER_ORDER=local
AI_HAIR_LOCAL_ENABLED=true
AI_HAIR_FORCE_LOCAL=true
LOCAL_HAIR_API_URL=http://127.0.0.1:8189
LOCAL_HAIR_API_TOKEN=
AI_HAIR_JOB_TIMEOUT_MS=900000
AI_HAIR_RETENTION_DAYS=30

# Optional paid/cloud providers. They are ignored by try-on while AI_HAIR_FORCE_LOCAL=true.
# https://fal.ai/models/fal-ai/image-editing/hair-change/api
FAL_KEY=
FAL_HAIR_MODEL=fal-ai/image-editing/hair-change
# Optional accounting value; leave empty if provider usage is reconciled elsewhere.
FAL_HAIR_COST_USD=

# Optional fallback providers
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image
REPLICATE_API_TOKEN=
REPLICATE_HAIR_MODEL_VERSION=
